TWENTY_API_URL=http://localhost:2020
TWENTY_APP_URL=http://localhost:2020
TWENTY_API_KEY=
TWENTY_WEBHOOK_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_INTAKE_STATE_TTL_SECONDS=1800

# Apify: enrichment runs automatically after Telegram intake (and via POST /jobs/enrich-creator).
# Set APIFY_TOKEN plus one actor ID per platform you scrape (Apify console → actor → ID).
APIFY_TOKEN=
APIFY_TIKTOK_ACTOR_ID=
APIFY_INSTAGRAM_ACTOR_ID=
APIFY_YOUTUBE_ACTOR_ID=
APIFY_X_ACTOR_ID=

# OpenAI: AI niche/tags/fit ratings after Telegram intake (and POST /jobs/summarize-creator).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Follow-up reminders (backend job); handoff follow-up dates are set in Twenty logic functions.
FOLLOW_UP_DAYS_NO_REPLY=3
TELEGRAM_REMINDER_CHAT_ID=

# Twenty UI intake form (UGC Ops page) — browser calls backend from localhost:2020
INTAKE_API_SECRET=
INTAKE_CORS_ORIGINS=http://localhost:2020

APP_ENV=local
LOG_LEVEL=INFO
